package finalproject;

import chat.Channel;
import chat.ChannelDAO;
import jakarta.annotation.PostConstruct;
import jakarta.faces.context.FacesContext;
import jakarta.faces.view.ViewScoped;
import jakarta.inject.Named;

import java.io.Serializable;
import java.util.ArrayList;
import java.util.List;
import java.util.Map;

@Named
@ViewScoped
public class ChannelBean implements Serializable {

    private int currentServerID;
    private int currentUserID;
    private String newChannelName;
    private List<Channel> channels;
    private String errorMessage;

    private ChannelDAO channelDAO;

    @PostConstruct
    public void init() {
        channelDAO = new ChannelDAO();
        channels = new ArrayList<>();

        Map<String, String> params = FacesContext.getCurrentInstance()
                .getExternalContext()
                .getRequestParameterMap();

        String serverIDParam = params.get("serverID");
        if (serverIDParam != null && !serverIDParam.isBlank()) {
            currentServerID = Integer.parseInt(serverIDParam);
        }

        if (currentServerID > 0) {
            loadChannels();
        }
    }

    public void loadChannels() {
        channels = channelDAO.getChannelsByServer(currentUserID, currentServerID);
    }

    public void createChannel() {
        errorMessage = null;

        if (!channelDAO.isValidChannelName(newChannelName)) {
            errorMessage = "Channel name is invalid.";
            return;
        }

        if (channelDAO.channelNameExistsInServer(currentServerID, newChannelName)) {
            errorMessage = "A channel with that name already exists in this server.";
            return;
        }

        boolean success = channelDAO.createChannel(currentUserID, currentServerID, newChannelName.trim());

           if (success) {
            newChannelName = "";
            loadChannels();
        } else {
            errorMessage = "You do not have permission to create channels or you are not a server member.";
        }
    }

    public String openChannel(int channelID) {
        return "channel.xhtml?faces-redirect=true&channelID=" + channelID;
    }

    public int getCurrentServerID() {
        return currentServerID;
    }

    public void setCurrentServerID(int currentServerID) {
        this.currentServerID = currentServerID;
    }

    public int getCurrentUserID() {
        return currentUserID;
    }

    public void setCurrentUserID(int currentUserID) {
        this.currentUserID = currentUserID;
    }

    public String getNewChannelName() {
        return newChannelName;
    }

    public void setNewChannelName(String newChannelName) {
        this.newChannelName = newChannelName;
    }

    public List<Channel> getChannels() {
        return channels;
    }

    public void setChannels(List<Channel> channels) {
        this.channels = channels;
    }

    public String getErrorMessage() {
        return errorMessage;
    }
}