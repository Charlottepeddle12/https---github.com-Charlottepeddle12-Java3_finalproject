package finalproject.chat;

import finalproject.Users.UserLogin;
import jakarta.annotation.PostConstruct;
import jakarta.annotation.PreDestroy;
import jakarta.enterprise.context.RequestScoped;
import jakarta.inject.Inject;
import jakarta.inject.Named;

import javax.naming.Context;
import javax.naming.InitialContext;
import javax.sql.DataSource;
import java.io.Serializable;
import java.sql.*;
import java.util.ArrayList;
import java.util.List;

@Named("ChannelService")
@SessionScoped
public class ChannelService implements Serializable {

    @Inject 
    private UserLogin login;
    private Connection conn;
    private int serverID;
    private int channelID;
    private String channelName;
    private String createChannelMessage;
    private String loadChannelsMessage;
    private String deleteChannelMessage;

    private List<Channel> channels = new ArrayList<>();

    @PostConstruct
    public void openConnection() {
        try {
            Context ctx = new InitialContext();
            DataSource ds = (DataSource) ctx.lookup("java:/comp/env/jdbc/javaproject");
            conn = ds.getConnection();
        } catch (Exception e) {
            createChannelMessage = e.getMessage();
        }

        createChannelMessage = null;
        loadChannelsMessage = null;
        deleteChannelMessage = null;
    }

    @PreDestroy
    public void closeConnection() {
        try {
            if (conn != null) conn.close();
        } catch (Exception ignored) {
        }
    }

    //helpers
    private boolean isLoggedIn() {
        return login != null && login.getUserId() > 0;
    }

    private boolean isValidChannelName(String name) {
        return name != null && !name.trim().isEmpty() && name.trim().length() <= 100;
    }

    private boolean isServerMember(int serverId, int userId) throws SQLException {
        String sql = "SELECT 1 FROM server_members WHERE serverID = ? AND userID = ?";
        try (PreparedStatement stmt = conn.prepareStatement(sql)) {
            stmt.setInt(1, serverId);
            stmt.setInt(2, userId);
            try (ResultSet rs = stmt.executeQuery()) {
                return rs.next();
            }
        }
    }

    private boolean canCreateChannel(int serverId, int userId) throws SQLException {
        // owner can always create
        String ownerSql = "SELECT 1 FROM servers WHERE serverID = ? AND ownerID = ?";
        try (PreparedStatement stmt = conn.prepareStatement(ownerSql)) {
            stmt.setInt(1, serverId);
            stmt.setInt(2, userId);
            try (ResultSet rs = stmt.executeQuery()) {
                if (rs.next()) {
                    return true;
                }
            }
        }

        // permission table check
        String permSql = """
            SELECT can_create_channel
            FROM server_member_permissions
            WHERE serverID = ? AND userID = ?
        """;
        try (PreparedStatement stmt = conn.prepareStatement(permSql)) {
            stmt.setInt(1, serverId);
            stmt.setInt(2, userId);
            try (ResultSet rs = stmt.executeQuery()) {
                return rs.next() && rs.getBoolean("can_create_channel");
            }
        }
    }

    private boolean channelNameExists(int serverId, String name) throws SQLException {
        String sql = "SELECT 1 FROM channels WHERE serverID = ? AND LOWER(name) = LOWER(?)";
        try (PreparedStatement stmt = conn.prepareStatement(sql)) {
            stmt.setInt(1, serverId);
            stmt.setString(2, name.trim());
            try (ResultSet rs = stmt.executeQuery()) {
                return rs.next();
            }
        }
    }

    private Integer getServerOwnerId(int serverId) throws SQLException {
        String sql = "SELECT ownerID FROM servers WHERE serverID = ?";
        try (PreparedStatement stmt = conn.prepareStatement(sql)) {
            stmt.setInt(1, serverId);
            try (ResultSet rs = stmt.executeQuery()) {
                if (rs.next()) {
                    return rs.getInt("ownerID");
                }
            }
        }
        return null;
    }

    private Integer getChannelServerId(int chId) throws SQLException {
        String sql = "SELECT serverID FROM channels WHERE channelID = ?";
        try (PreparedStatement stmt = conn.prepareStatement(sql)) {
            stmt.setInt(1, chId);
            try (ResultSet rs = stmt.executeQuery()) {
                if (rs.next()) {
                    return rs.getInt("serverID");
                }
            }
        }
        return null;
    }

    //create
    public void createChannel() {
        createChannelMessage = "";

        if (conn == null || !isLoggedIn()) {
            createChannelMessage = "Not connected to database or user not logged in.";
            return;
        }

        if (serverID <= 0) {
            createChannelMessage = "A valid server must be selected.";
            return;
        }

        if (!isValidChannelName(channelName)) {
            createChannelMessage = "Channel name cannot be empty and must be 100 characters or less.";
            return;
        }

        try {
            if (!isServerMember(serverID, login.getUserId())) {
                createChannelMessage = "You are not a member of this server.";
                return;
            }

            if (!canCreateChannel(serverID, login.getUserId())) {
                createChannelMessage = "You do not have permission to create channels in this server.";
                return;
            }

            if (channelNameExists(serverID, channelName)) {
                createChannelMessage = "A channel with this name already exists in this server.";
                return;
            }

            String sql = "INSERT INTO channels (serverID, name, created_by) VALUES (?, ?, ?)";
            try (PreparedStatement stmt = conn.prepareStatement(sql)) {
                stmt.setInt(1, serverID);
                stmt.setString(2, channelName.trim());
                stmt.setInt(3, login.getUserId());

                int rows = stmt.executeUpdate();
                if (rows > 0) {
                    createChannelMessage = "Channel created successfully.";
                    channelName = null;
                    loadChannelsByServer(serverID);
                } else {
                    createChannelMessage = "Channel creation failed.";
                }
            }

        } catch (SQLException e) {
            if (e.getMessage() != null && e.getMessage().contains("Duplicate entry")) {
                createChannelMessage = "A channel with this name already exists in this server.";
            } else {
                createChannelMessage = "Error creating channel: " + e.getMessage();
            }
        }
    }

    //load
    public void loadChannelsByServer(int serverId) {
        loadChannelsMessage = "";
        channels.clear();

        if (conn == null || !isLoggedIn()) {
            loadChannelsMessage = "Not connected to database or user not logged in.";
            return;
        }

        try {
            if (!isServerMember(serverId, login.getUserId())) {
                loadChannelsMessage = "You are not a member of this server.";
                return;
            }

            String sql = """
                SELECT channelID, serverID, name, created_by, created_at
                FROM channels
                WHERE serverID = ?
                ORDER BY created_at ASC
            """;

            try (PreparedStatement stmt = conn.prepareStatement(sql)) {
                stmt.setInt(1, serverId);

                try (ResultSet rs = stmt.executeQuery()) {
                    while (rs.next()) {
                        Channel channel = new Channel();
                        channel.setChannelID(rs.getInt("channelID"));
                        channel.setServerID(rs.getInt("serverID"));
                        channel.setName(rs.getString("name"));
                        channel.setCreatedBy((Integer) rs.getObject("created_by"));
                        channel.setCreatedAt(rs.getTimestamp("created_at"));
                        channels.add(channel);
                    }
                }
            }

            if (channels.isEmpty()) {
                loadChannelsMessage = "No channels found for this server.";
            } else {
                loadChannelsMessage = "Channels loaded successfully.";
            }

        } catch (SQLException e) {
            loadChannelsMessage = "Failed to load channels: " + e.getMessage();
        }
    }

    //delete
    // i made only server owner can delete channels
    public void deleteChannel(int chId) {
        deleteChannelMessage = "";

        if (conn == null || !isLoggedIn()) {
            deleteChannelMessage = "Not connected to database or user not logged in.";
            return;
        }

        try {
            Integer serverId = getChannelServerId(chId);
            if (serverId == null) {
                deleteChannelMessage = "Channel not found.";
                return;
            }

            if (!isServerMember(serverId, login.getUserId())) {
                deleteChannelMessage = "You are not a member of this server.";
                return;
            }

            Integer ownerId = getServerOwnerId(serverId);
            if (ownerId == null || ownerId != login.getUserId()) {
                deleteChannelMessage = "Only the server owner can delete channels.";
                return;
            }

            String sql = "DELETE FROM channels WHERE channelID = ?";
            try (PreparedStatement stmt = conn.prepareStatement(sql)) {
                stmt.setInt(1, chId);
                int rows = stmt.executeUpdate();

                if (rows > 0) {
                    deleteChannelMessage = "Channel deleted successfully.";
                    loadChannelsByServer(serverId);
                } else {
                    deleteChannelMessage = "Channel deletion failed.";
                }
            }

        } catch (SQLException e) {
            deleteChannelMessage = "Error deleting channel: " + e.getMessage();
        }
    }


    
    public int getServerID() {
        return serverID;
    }

    public void setServerID(int serverID) {
        this.serverID = serverID;
    }

    public int getChannelID() {
        return channelID;
    }

    public void setChannelID(int channelID) {
        this.channelID = channelID;
    }

    public String getChannelName() {
        return channelName;
    }

    public void setChannelName(String channelName) {
        this.channelName = channelName;
    }

    public String getCreateChannelMessage() {
        return createChannelMessage;
    }

    public String getLoadChannelsMessage() {
        return loadChannelsMessage;
    }

    public String getDeleteChannelMessage() {
        return deleteChannelMessage;
    }

    public List<Channel> getChannels() {
        return channels;
    }

    public int getCurrentUserID() {
        return login != null ? login.getUserId() : -1;
    }
}